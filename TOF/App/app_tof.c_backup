//////////////////////////////////////////////////////////////////////////////魹ｽﾔｼ魹ｽ魹ｽﾄｴ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ

/* ﾃｰ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ8魹ｽ魹ｽ魹ｽ魹ｽ魹ｽﾝｼ魹ｽ魹ｽ琢ｩ */
static void _sort_8(int16_t *arr) 
{
    int16_t temp;
    for (int i = 0; i < 7; i++) 
	{
        for (int j = 0; j < 7 - i; j++) 
		{
            if (arr[j] > arr[j + 1]) 
			{
                temp = arr[j];
                arr[j] = arr[j + 1];
                arr[j + 1] = temp;
            }
        }
    }
}


void Process_16Columns_Robust(RANGING_SENSOR_Result_t *L, RANGING_SENSOR_Result_t *R, float *out_heights)
{
    int16_t col_buffer[8];
    uint8_t zones_per_line = 8;

    // 魹ｽ魹ｽ魹ｽ魹ｽ16魹ｽ魹ｽ (0-7魹ｽ魹ｽ魹ｽ㫗ｫｸ魹ｽ魹ｽ魹ｽ, 8-15魹ｽ魹ｽ魹ｽﾒｴ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ)
    for (int col = 0; col < 16; col++) 
    {
        // 1. 魹ｽ魹ｽﾈ｡魹ｽ魹ｽ魹ｽ魹ｽ魹ｽﾚｳ魹ｽ魹ｽﾈｷ魹ｽ魹ｽ魹ｽ魹ｽﾏｵ魹ｽ8魹ｽ魹ｽ魹ｽ魹ｽ
        for (int row = 0; row < 8; row++) 
        {
            int zone_idx = (row * zones_per_line) + (col % 8);
            int16_t raw_dist, base_dist;

            if (col < 8) { // 魹ｽ魹ｽ魹ｽ
                raw_dist = L->ZoneResult[zone_idx].Distance[0];
                base_dist = BaseMap_L[zone_idx];
            } else { // 魹ｽﾒｲ魹ｽ
                raw_dist = R->ZoneResult[zone_idx].Distance[0];
                base_dist = BaseMap_R[zone_idx];
            }

            // --- 魹ｽﾞｸﾄｲ魹ｽ魹ｽﾖｿ魹ｽﾊｼ ---
            // 1.1 魹ｽ魹ｽ魹ｽ魹ｽﾔｭﾊｼ魹ｽ魹ｽ魹ｽ魹ｽ詝ｨ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ槵ｩ
            int16_t diff = base_dist - raw_dist;
            if (diff < 0) diff = 0; 

            // 1.2 ﾓｦ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽﾒｲ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽﾖｱ魹ｽﾟｶ魹ｽ = 魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ * cos(theta)
            // ﾊｹ魹ｽ魹ｽ魹ｽ羝ｨ魹ｽ魹ｽ魹ｽ CosMap 魹ｽ魹ｽ魹ｽ魹ｽ
            float corrected_h = (float)diff * CosMap[zone_idx];
            
            // 1.3 魹ｽ魹ｽ魹ｽ欞ｺ魹ｽ魹ｽ魹ｽ魹ｽﾐｺ魹ｽ魹ｽ魹ｽ魹ｽﾋｲ魹ｽ
            col_buffer[row] = (int16_t)corrected_h;
            // --- 魹ｽﾞｸﾄｲ魹ｽ魹ｽﾖｽ魹ｽ魹ｽ魹ｽ ---
        }

        // 2. 魹ｽ魹ｽﾖｵ魹ｽﾋｲ魹ｽ
        _sort_8(col_buffer);

        // 3. 魹ｽ魹ｽ魹ｽ魹ｽﾆｽ魹ｽ魹ｽ魹ｽ魹ｽﾈ｡魹ｽﾐｼ魹ｽ4魹ｽ魹ｽ魹ｽ魹ｽ魹ｽﾆｽ魹ｽ魹ｽﾖｵ
        float robust_avg = (col_buffer[2] + col_buffer[3] + col_buffer[4] + col_buffer[5]) / 4.0f;
        
        out_heights[col] = robust_avg;
    }
}

float Calculate_Tray_Saturation(float *col_heights)
{
    float current_area = 0;
    float col_width = 12.5f;   // ﾃｿ魹ｽﾐｿ魹ｽ魹ｽ魹ｽ 12.5mm
    float max_height = 100.0f; // 魹ｽﾅｼ魹ｽ魹ｽ魹ｽ魹ｽ 100mm
    float total_tray_area = 200.0f * 100.0f; // 魹ｽﾜｽ魹ｽ魹ｽ魹ｽ魹ｽ 20000 mm^2

    for (int i = 0; i < 16; i++) {
        // ﾃｿﾒｻ魹ｽﾐｵﾄｽ魹ｽ魹ｽ魹ｽ魹ｽ = 魹ｽ魹ｽ魹ｽ魹ｽﾂｳ魹ｽ魹ｽ魹ｽﾟｶ魹ｽ * 魹ｽﾐｿ魹ｽ
        // 魹ｽ魹ｽ魹ｽﾆｸﾟｶﾈｲ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽﾅｼﾜｸﾟｶ魹ｽ
        float h = col_heights[i];
        if (h > max_height) h = max_height;
        
        current_area += (h * col_width);
    }

    // 魹ｽﾕｼ魹ｽﾕｼ魹ｽ魹ｽ魹ｽ魹ｽ = (魹ｽ魹ｽﾇｰ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ / 魹ｽﾜｽ魹ｽ魹ｽ魹ｽ魹ｽ) * 100%
	
	
    return (current_area / total_tray_area) * 100.0f;
}

// 魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽﾄｼ魹ｽﾄｩﾎｲ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽﾐ｡魹ｽ魹ｽ魹ｽ魹ｽ
void Serial_Output_For_Python(float *cols, float sat) 
{
    // ﾊｹ魹ｽ魹ｽ魹ｽﾘｶ魹ｽﾇｰﾗｺ @DATA 魹ｽ魹ｽ魹ｽ魹ｽ Python 魹ｽ魹ｽ魹ｽﾋｵ魹ｽ魹ｽ魹ｽﾊｼ魹ｽ魹ｽ魹ｽ魹ｽﾏ｢
    printf("@DATA:"); 
    for(int i = 0; i < 16; i++) 
    {
        printf("%.1f,", cols[i]);
    }
    printf("%.2f¥n", sat); // 魹ｽ魹ｽﾎｲ魹ｽ魹ｽ魹ｽ魹ｽ
}


