/* ﾗ｢魹ｽ筌ｺ魹ｽ魹ｽﾈｷ魹ｽ魹ｽ魹ｽ魹ｽ app_tof.c 魹ｽﾄｶ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽﾍｷ魹ｽﾄｼ魹ｽ魹ｽﾂｷ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽﾈｫ魹ｽ魹ｽ/魹ｽ魹ｽﾌｬ魹ｽ魹ｽ魹ｽ魹ｽ */
extern float sat;               // 魹ｽ魹ｽ魹ｽ魹ｽ main.c 魹ｽﾐｶ魹ｽ魹ｽ魹ｽ魹ｽﾈｫ魹ｽﾖｱ魹ｽ魹ｽﾍｶﾈｱ魹ｽ魹ｽ魹ｽ
static uint8_t sensors_started = 0; // 魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽﾗｴﾌｬ魹ｽ魹ｽﾖｾﾎｻ
static RANGING_SENSOR_ProfileConfig_t Profile; // 魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽﾃｽ盪ｹ魹ｽ魹ｽ


/**
  * @brief  魹ｽﾞｸﾄｺ魹ｽﾄｷ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽﾊｽ魹ｽ魹ｽ犇ｦ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ
  * @note   ﾉｾ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽﾚｲ魹ｽ while(1)魹ｽ魹ｽ魹ｽ魹ｽ main.c 魹ｽ魹ｽ while(1) 魹ｽ魹ｽ魹ｽ魹ｽﾑｭ魹ｽ魹ｽ
  */
static void MX_53L8A1_MultiSensorRanging_Process(void)
{
  uint8_t i;
  int32_t status;
  static RANGING_SENSOR_Result_t Result_L;
  static RANGING_SENSOR_Result_t Result_R;
  uint8_t has_L = 0;
  uint8_t has_R = 0;
  float feature_columns[16];

  // --- 1. 魹ｽ魹ｽ魹ｽ魹ｽ/魹ｽ魹ｽﾊｼ魹ｽ魹ｽ魹ｽﾗｶ魹ｽ (魹ｽ魹ｽ魹ｽﾚｵ魹ｽﾒｻ魹ｽﾎｽ魹ｽ魹ｽ魹ｽﾊｱﾖｴ魹ｽ魹ｽ) ---
  if (sensors_started == 0) 
  {
    // 魹ｽ魹ｽ魹ｽﾃｲ魹ｽ魹ｽ魹ｽ
    Profile.RangingProfile = RS_PROFILE_8x8_CONTINUOUS;
    Profile.TimingBudget = 20;    // 魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ TIMING_BUDGET 魹ｽ弽ｨ魹ｽ魹ｽ魹ｽﾞｸ魹ｽ
    Profile.Frequency = RANGING_FREQUENCY;       // 魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ RANGING_FREQUENCY 魹ｽ弽ｨ魹ｽ魹ｽ魹ｽﾞｸ魹ｽ
    Profile.EnableAmbient = 0;
    Profile.EnableSignal = 0;

    printf("Starting Sensors...¥n");
    for (i = 0; i < RANGING_SENSOR_INSTANCES_NBR; i++)
    {
      if (i == VL53L8A1_DEV_CENTER) continue; 
      if (ToF_Present[i] != 1) continue;

      VL53L8A1_RANGING_SENSOR_ConfigProfile(i, &Profile);
      status = VL53L8A1_RANGING_SENSOR_Start(i, RS_MODE_BLOCKING_CONTINUOUS);
      
      if (status != BSP_ERROR_NONE) {
        printf("Sensor %d Start Failed! Status: %ld¥n", i, status);
      }
    }
    
    printf("Waiting for sensor stability (3s)...¥n");
    HAL_Delay(3000); 
    printf("System Ready. Continuous Scanning Started.¥n");
    
    sensors_started = 1; // 魹ｽ魹ｽ魹ｽ魹ｽﾑｾ魹ｽ魹ｽ魹ｽ
    return; // 魹ｽ魹ｽﾒｻ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽﾉ｣魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ main ﾑｭ魹ｽ魹ｽ
  }

  // --- 2. 魹ｽ魹ｽ魹ｽﾝｲﾉｼ魹ｽ魹ｽﾗｶ魹ｽ (魹ｽ魹ｽ魹ｽ魹ｽ main ﾑｭ魹ｽ魹ｽ魹ｽﾚｲ魹ｽﾍ｣魹ｽ魹ｽ魹ｽﾃ｣魹ｽ魹ｽ魹ｽ魹ｽ驒ｻ魹ｽ魹ｽ魹ｽ魹ｽﾒｪ while(1)) ---
  
  // 魹ｽ魹ｽ魹ｽﾔｻ魹ｽﾈ｡魹ｽ魹ｽ犇ｫ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ
  if (VL53L8A1_RANGING_SENSOR_GetDistance(VL53L8A1_DEV_LEFT, &Result_L) == BSP_ERROR_NONE) 
  {
    has_L = 1;
  }

  // 魹ｽ魹ｽ魹ｽﾔｻ魹ｽﾈ｡魹ｽﾒｲ犇ｫ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ
  if (VL53L8A1_RANGING_SENSOR_GetDistance(VL53L8A1_DEV_RIGHT, &Result_R) == BSP_ERROR_NONE) 
  {
    has_R = 1;
  }

  // --- 3. 魹ｽ羚ｨ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ ---
  // ﾖｻ魹ｽﾐｵ魹ｽ魹ｽ魹ｽ魹ｽﾟｶ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽﾍｬ魹ｽ魹ｽﾊｱ魹ｽ魹ｽ魹ｽﾅｽ魹ｽ魹ｽﾐｼ魹ｽ魹ｽ罐ｨ魹ｽ魹ｽﾖｹ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽﾋｸ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽﾝｲ魹ｽ魹ｽ魹ｽ魹ｽ槵ｩ
  if (has_L && has_R) 
  {
    // A. 魹ｽ魹ｽﾈ｡16魹ｽﾐｸﾟｶ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ
    Process_16Columns_Robust(&Result_L, &Result_R, feature_columns);
    
    // B. 魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽﾌｱ魹ｽ魹ｽﾍｶ魹ｽ
    float saturation_val = Calculate_Tray_Saturation(feature_columns);
    
    // C. 魹ｽ魹ｽﾒｪ魹ｽ魹ｽﾍｬ魹ｽ魹ｽ魹ｽ魹ｽﾈｫ魹ｽﾖｱ魹ｽ魹ｽ魹ｽ sat魹ｽ魹ｽ魹ｽ魹ｽ main.c 魹ｽ魹ｽ魹ｽﾆｶ魹ｽ魹ｽﾏｴ魹ｽ魹ｽﾟｼ魹ｽ魹ｽ魹ｽﾈ｡
    sat = saturation_val; 

    // D. 魹ｽ魹ｽ魹ｽ魹ｽ魹ｽﾕｶ魹ｽ魹ｽ魹ｽﾊｾ (魹ｽ魹ｽﾌｬﾋ｢魹ｽ魹ｽﾐｧ魹ｽ魹ｽ)
    printf("¥033[H"); // ANSI ﾗｪ魹ｽ魹ｽ魹ｽ槵ｺ魹ｽ魹ｽ彅ｴﾎｻ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽﾏｽ魹ｽ
    printf("=== Tray Monitoring System ===¥n");
    printf("Saturation: %.2f%%  |  Max Height: %.1f mm¥n", saturation_val, feature_columns[8]);
    
    // E. 魹ｽ魹ｽ魹ｽ魹ｽ魹ｽﾍｼ魹ｽ魹ｽﾊｾ
    print_compensated_height_matrix(&Result_L, &Result_R); 
    
    // F. 魹ｽ魹ｽ魹ｽ魹ｽﾔｭﾊｼ魹ｽ魹ｽ魹ｽ魹ｽ (魹ｽ魹ｽ Python 魹ｽ魹ｽ 魹ｽ魹ｽ魹ｽ魹ｽﾊｹ魹ｽ魹ｽ)
    Serial_Output_For_Python(feature_columns, saturation_val);
  }

  // 魹ｽ魹ｽ魹ｽ魹ｽﾖｴ魹ｽ魹ｽ魹ｽ魹ｽﾏ｣魹ｽ魹ｽﾔｶ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ main.c 魹ｽ魹ｽ while(1) 
  // 魹ｽ魹ｽﾒｻﾈｦﾑｭ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽﾙｴﾎｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ顥ｬﾊｵ魹ｽﾖ｡魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ
}



static void print_merged_result(RANGING_SENSOR_Result_t *L, RANGING_SENSOR_Result_t *R)
{
  int8_t row, col;
  uint8_t zones_per_line = 8; // 8x8 ﾄ｣ﾊｽ魹ｽﾌｶ魹ｽﾎｪ 8

  // 1. 魹ｽ魹ｽﾓ｡魹ｽ魹ｽ魹ｽ魹ｽ魹ｽﾖｸ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ (16魹ｽﾐｿ魹ｽ)
  for (col = 0; col < zones_per_line * 2; col++) printf("------");
  printf("--¥n");

  // 2. 魹ｽ魹ｽ魹ｽﾐｴ魹ｽﾓ｡魹ｽ魹ｽ魹ｽ魹ｽ
  for (row = 0; row < zones_per_line; row++)
  {
    // --- 魹ｽ魹ｽﾓ｡魹ｽ㫗ｫｸ魹ｽ魹ｽ魹ｽ(L)魹ｽ魹ｽ魹ｽ魹ｽﾒｻ魹ｽ魹ｽ ---
    for (col = (zones_per_line - 1); col >= 0; col--)
    {
      uint8_t zone_idx = (row * zones_per_line) + col;
      if (L->ZoneResult[zone_idx].NumberOfTargets > 0)
        printf("%4ld ", (long)L->ZoneResult[zone_idx].Distance[0]);
      else
        printf("   X ");
    }

    // --- 魹ｽ魹ｽ魹ｽﾒｷﾖｸ魹ｽ魹ｽ ---
    printf(" | ");

    // --- 魹ｽ魹ｽﾓ｡魹ｽﾒｴ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ(R)魹ｽ魹ｽ魹ｽ魹ｽﾒｻ魹ｽ魹ｽ ---
    for (col = (zones_per_line - 1); col >= 0; col--)
    {
      uint8_t zone_idx = (row * zones_per_line) + col;
      if (R->ZoneResult[zone_idx].NumberOfTargets > 0)
        printf("%4ld ", (long)R->ZoneResult[zone_idx].Distance[0]);
      else
        printf("   X ");
    }
    printf("¥n");
  }

  // 3. 魹ｽ魹ｽﾓ｡魹ｽﾗｲ魹ｽ魹ｽﾖｸ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ
  for (col = 0; col < zones_per_line * 2; col++) printf("------");
  printf("--¥n");
}

/**
 * @brief 魹ｽ魹ｽﾓ｡魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽﾊｵﾊｱ魹ｽﾟｶﾈｾ魹ｽ魹ｽ魹ｽBase - Raw魹ｽ魹ｽ* Cos
 * 魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽﾅｼ魹ｽﾊｱ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽﾓｦ魹ｽ魹ｽﾈｫ魹ｽ魹ｽ 0
 */
static void print_compensated_height_matrix(RANGING_SENSOR_Result_t *L, RANGING_SENSOR_Result_t *R)
{
    int8_t row, col;
    uint8_t zones_per_line = 8;

    printf("¥n--- Compensated Height Map (LEFT | RIGHT) [Unit: mm] ---¥n");
    for (col = 0; col < zones_per_line * 2; col++) printf("-----");
    printf("¥n");

    for (row = 0; row < zones_per_line; row++)
    {
        // --- 魹ｽ魹ｽﾓ｡魹ｽ㫗ｫｸ魹ｽ魹ｽ魹ｽ魹ｽﾟｶ魹ｽ (魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽﾔｷ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽﾎｻ) ---
        for (col = (zones_per_line - 1); col >= 0; col--)
        {
            uint8_t idx = (row * zones_per_line) + col;
            int16_t diff = BaseMap_L[idx] - L->ZoneResult[idx].Distance[0];
            float h = (diff > 0) ? (float)diff * CosMap[idx] : 0; // 魹ｽ魹ｽ魹ｽﾋｸ魹ｽﾖｵ
            
            // 魹ｽ魹ｽ魹ｽ魹ｽﾅｺ魹ｽ魹ｽ魹ｽﾐｧ魹ｽ魹ｽ魹ｽ魹ｽﾓ｡ X
            if (L->ZoneResult[idx].NumberOfTargets > 0)
                printf("%3.0f  ", h);
            else
                printf("  X  ");
        }

        printf(" | ");

        // --- 魹ｽ魹ｽﾓ｡魹ｽﾒｴ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽﾟｶ魹ｽ ---
        for (col = (zones_per_line - 1); col >= 0; col--)
        {
            uint8_t idx = (row * zones_per_line) + col;
            int16_t diff = BaseMap_R[idx] - R->ZoneResult[idx].Distance[0];
            float h = (diff > 0) ? (float)diff * CosMap[idx] : 0;
            
            if (R->ZoneResult[idx].NumberOfTargets > 0)
                printf("%3.0f  ", h);
            else
                printf("  X  ");
        }
        printf("¥n");
    }

    for (col = 0; col < zones_per_line * 2; col++) printf("-----");
    printf("¥n");
}


static void print_result(RANGING_SENSOR_Result_t *Result)
{
  int8_t i;
  int8_t j;
  int8_t k;
  int8_t l;
  uint8_t zones_per_line;

  zones_per_line = ((Profile.RangingProfile == RS_PROFILE_8x8_AUTONOMOUS) ||
                    (Profile.RangingProfile == RS_PROFILE_8x8_CONTINUOUS)) ? 8 : 4;

  printf("Cell Format :¥n¥n");
  for (l = 0; l < RANGING_SENSOR_NB_TARGET_PER_ZONE; l++)
  {
    printf(" ¥033[38;5;10m%20s¥033[0m : %20s¥n", "Distance [mm]", "Status");
    if ((Profile.EnableAmbient != 0) || (Profile.EnableSignal != 0))
    {
      printf(" %20s : %20s¥n", "Signal [kcps/spad]", "Ambient [kcps/spad]");
    }
  }

  printf("¥n¥n");

  for (j = 0; j < Result->NumberOfZones; j += zones_per_line)
  {
    for (i = 0; i < zones_per_line; i++) /* number of zones per line */
    {
      printf(" -----------------");
    }
    printf("¥n");

    for (i = 0; i < zones_per_line; i++)
    {
      printf("|                 ");
    }
    printf("|¥n");

    for (l = 0; l < RANGING_SENSOR_NB_TARGET_PER_ZONE; l++)
    {
      /* Print distance and status */
      for (k = (zones_per_line - 1); k >= 0; k--)
      {
        if (Result->ZoneResult[j + k].NumberOfTargets > 0)
          printf("| ¥033[38;5;10m%5ld¥033[0m  :  %5ld ",
                 (long)Result->ZoneResult[j + k].Distance[l],
                 (long)Result->ZoneResult[j + k].Status[l]);
        else
          printf("| %5s  :  %5s ", "X", "X");
      }
      printf("|¥n");

      if ((Profile.EnableAmbient != 0) || (Profile.EnableSignal != 0))
      {
        /* Print Signal and Ambient */
        for (k = (zones_per_line - 1); k >= 0; k--)
        {
          if (Result->ZoneResult[j + k].NumberOfTargets > 0)
          {
            if (Profile.EnableSignal != 0)
            {
              printf("| %5ld  :  ", (long)Result->ZoneResult[j + k].Signal[l]);
            }
            else
              printf("| %5s  :  ", "X");

            if (Profile.EnableAmbient != 0)
            {
              printf("%5ld ", (long)Result->ZoneResult[j + k].Ambient[l]);
            }
            else
              printf("%5s ", "X");
          }
          else
            printf("| %5s  :  %5s ", "X", "X");
        }
        printf("|¥n");
      }
    }
  }

  for (i = 0; i < zones_per_line; i++)
  {
    printf(" -----------------");
  }
  printf("¥n");
}

