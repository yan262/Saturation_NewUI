# ============================================================
# 电缆桥架饱和度监控系统 — 环境变量配置模板
# ============================================================
# 使用方法:
#   1. 复制此文件为 .env  (cp .env.example .env)
#   2. 填入你的真实配置值
#   3. .env 文件不会提交到 Git（已在 .gitignore 中）
# ============================================================

# ── OneNet 物联网平台配置（必填）──
ONENET_PRODUCT_ID="IqV8M48sQQ"
ONENET_DEVICE_NAME="Saturation_Detection"
ONENET_TOKEN="version=2018-10-31&res=products%2FIqV8M48sQQ%2Fdevices%2FSaturation_Detection&et=2058447118&method=md5&sign=rzM7OnlFyCMOexl5ixFGYQ%3D%3D"

# ── 服务配置 ──
HOST=0.0.0.0
PORT=8000

# ── 默认监控设置 ──
REFRESH_RATE=2
ALARM_THRESHOLD=85

# ── JWT 认证配置 ──
# 生产环境务必修改为随机长字符串（可用 python -c "import secrets; print(secrets.token_urlsafe(32))" 生成）
JWT_SECRET=change-me-to-a-random-secret-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── LDAP/AD 配置（可选，不使用 LDAP 可保持默认）──
LDAP_ENABLED=False
LDAP_SERVER=ldap://your-ad-server:389
LDAP_BASE_DN=dc=company,dc=com
LDAP_DOMAIN=COMPANY
